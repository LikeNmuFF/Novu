{
  "outputDirectory": "website",
  "functions": {
    "api/*.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/static/(.*)", "dest": "/website/static/$1" },
    { "src": "/(.*)", "dest": "/website/$1" }
  ]
}
